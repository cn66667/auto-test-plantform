<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="API Test Suite" parallel="false">
    <parameter name="environment" value="test"/>
    
    <listeners>
        <listener class-name="com.apitest.core.listener.TestSuiteListener"/>
        <listener class-name="com.apitest.core.listener.TestMethodListener"/>
    </listeners>
    
    <test name="User API Tests">
        <classes>
            <class name="com.apitest.cases.testcases.UserApiTest"/>
        </classes>
    </test>
    
    <test name="Resource API Tests">
        <classes>
            <class name="com.apitest.cases.testcases.ResourceApiTest"/>
        </classes>
    </test>
    
    <test name="Advanced API Tests">
        <classes>
            <class name="com.apitest.cases.testcases.AdvancedApiTest"/>
        </classes>
    </test>
</suite>
